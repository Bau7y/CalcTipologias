{
  "productName": "Calculadora ONT",
  "version": "1.0.0",
  "identifier": "cr.go.sancarloscr.bienesimmuebles",
  "build": {
    "frontendDist": "../src/"
  },
  "app": {
    "windows": [
      {
        "title": "Calculadora de Tipologías y Depreciación · Bienes Inmuebles San Carlos",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}